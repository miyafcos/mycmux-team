{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CMux Linux",
  "version": "0.1.0",
  "identifier": "com.cai0baa.cmuxlinux",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CMux Linux",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage",
      "deb"
    ],
    "category": "Utility",
    "shortDescription": "Linux terminal workspace manager",
    "longDescription": "CMux Linux is a Linux-native terminal workspace manager built with Tauri and React.",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
