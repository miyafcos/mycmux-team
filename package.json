{
  "name": "mycmux-lite",
  "private": false,
  "version": "0.3.3",
  "description": "Team-shared terminal workspace (lite edition of mycmux)",
  "repository": {
    "type": "git",
    "url": "https://github.com/miyafcos/mycmux-team.git"
  },
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:mycmux-ui": "tsc && VITE_UI_VARIANT=mycmux vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev:default": "npm run tauri dev",
    "tauri:dev:mycmux-ui": "VITE_UI_VARIANT=mycmux npm run tauri dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "allotment": "^1.0.9",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.1.0",
    "ghostty-web": "^0.4.0",
    "immer": "^11.1.4",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
